set synth.sample-rate 48000
set audio.sample-format 24bits
set audio.file.format s24
set audio.period-size 64
set audio.periods 8
set audio.coreaudio.device default
#set audio.coreaudio.device "BlackHole 2ch"
#set audio.coreaudio.device "Fireface UCX (23934053)"

#set synth.verbose "True"
set synth.gain 1
set synth.polyphony 2048
set synth.chorus.active False
set synth.reverb.room-size 0.5
set synth.reverb.damp 0.5
