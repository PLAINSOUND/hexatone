{
  "type": "module",
  "private": true,
  "name": "plainsound-hexatone",
  "repository": "git@github.com:PLAINSOUND/hexatone.git",
  "scripts": {
    "start": "vite",
    "osc-bridge": "node osc-bridge/index.js",
    "build-bridge": "npx pkg osc-bridge/index.js --config osc-bridge/package.json --out-path osc-bridge/dist",
    "build": "vite build && node generate-sw.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "normalize.css": "^8.0.1",
    "preact": "^10.28.4",
    "webmidi": "^3.1.14",
    "xen-dev-utils": "^0.12.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@preact/preset-vite": "^2.10.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.2",
    "prop-types": "^15.8.1",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^2.1.8",
    "workbox-build": "^7.4.0"
  },
  "packageManager": "yarn@4.13.0"
}
